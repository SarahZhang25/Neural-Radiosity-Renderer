<scene version='3.0.0'>
    <default name="spp" value="1024"/>
    <default name="res" value="512"/>

    <integrator type='path'>
        <integer name="max_depth" value="8"/>
    </integrator>
    <!-- <integrator type='direct'/> -->

    <sensor type="perspective" id="sensor">
        <transform name="to_world">
            <lookat target="0.0, 0.0, 1.0"
                    origin="4.0, 4.0, 3.5"
                    up    ="0.0, 0.0, 1.0"/>
        </transform>
        <sampler type="independent">
            <integer name="sample_count" value="$spp"/>
        </sampler>
        <film type="hdrfilm">
            <rfilter type="box"/>
            <integer name="width"  value="$res"/>
            <integer name="height" value="$res"/>
        </film>
    </sensor>

    <!-- Primary red cube (direct light) - bright color to reflect light -->
    <shape type="cube">
        <transform name="to_world">
            <translate x="-1.5" y="0.0" z="1.0"/>
            <scale value="0.6"/>
        </transform>
        <bsdf type="diffuse">
            <rgb name="reflectance" value="0.9, 0.3, 0.3"/> <!-- red -->
        </bsdf>
    </shape>

    <!-- Secondary blue cube (indirect light) - positioned to receive bounced light -->
    <shape type="cube">
        <transform name="to_world">
            <translate x="1.5" y="0.0" z="1.0"/>
            <scale value="0.6"/>
        </transform>
        <bsdf type="diffuse">
            <rgb name="reflectance" value="0.3, 0.3, 0.9"/> 
        </bsdf>
    </shape>

    <!-- Direct light source pointing at first cube -->
    <emitter type="point" id="light">
        <point name="position" x="-2.0" y="2.0" z="4.0"/>
        <rgb name="intensity" value="100.0"/>
    </emitter>
</scene>