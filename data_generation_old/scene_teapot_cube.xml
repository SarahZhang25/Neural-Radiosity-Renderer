<scene version='3.0.0'>
    <default name="spp" value="1024"/>
    <default name="res" value="512"/>

    <integrator type='path'>
        <integer name="max_depth" value="10"/>
    </integrator>

    <sensor type="perspective" id="sensor">
        <transform name="to_world">
            <lookat target="0.0, 0.0, 1.5"
                    origin="4.0, 4.0, 3.0"
                    up    ="0.0, 0.0, 1.0"/>
        </transform>
        <sampler type="independent">
            <integer name="sample_count" value="$spp"/>
        </sampler>
        <film type="hdrfilm">
            <rfilter type="box"/>
            <integer name="width"  value="$res"/>
            <integer name="height" value="$res"/>
        </film>
    </sensor>

    <!-- Teapot (receives indirect light from cube) -->
    <shape type="ply" id="teapot">
        <string name="filename" value="teapot.ply"/>
        <transform name="to_world">
            <translate x="1" y="-2.5" z="0.0"/>
            <scale value="0.3"/>
        </transform>
        <bsdf type="diffuse">
            <rgb name="reflectance" value="0.8, 0.8, 0.9"/>
        </bsdf>
    </shape>

    <!-- Cube (directly lit, reflects light to teapot) -->
    <shape type="cube">
        <transform name="to_world">
            <translate x="-1.0" y="1.0" z="1.5"/>
            <scale value="0.5"/>
        </transform>
        <bsdf type="diffuse">
            <rgb name="reflectance" value="1.0, 0.0, 0.0"/>
        </bsdf>
    </shape>

    <!-- Direct light source pointing at cube -->
    <emitter type="point" id="light">
        <point name="position" x="2.5" y="-2.5" z="4.0"/>
        <rgb name="intensity" value="100.0"/>
    </emitter>
</scene>